<mujoco model="block_pickup_trailer">
  <!--
      Simplified block-body pickup + block flatbed trailer, real scale.
      NO SUSPENSION: wheels are rigidly mounted at exactly tire-radius
      height, so ride height is set purely by tire-ground contact.

      TRUCK : single box 5.90 x 2.03 x 1.60 m, explicit <inertial>
              (sprung 2200 kg, COM +0.26 m, diaginertia 1300/5500/6000),
              wheelbase 3.70 m, track 1.72 m, tires r=0.41.
      TRAILER: flat deck 2.44 x 1.52 m, single axle at deck center,
              tongue TONGUE_LEN, tires r=0.345. Subtree between the
              TRAILER_START/END markers is regenerated by the Python script.

      LANE: 3.66 m (12 ft, US standard), yellow lines both sides at
            y = +-1.83 m, non-colliding.

      SENSORS: IMU (accel + gyro + orientation quat) on truck and trailer,
               ball-joint quat on the hitch = trailer angle rel. truck.

      MARKERS: CAR_ROOT_START/END and CAR_END are used by the Python
               script (PIVOT_MODE / PLANAR_MODE splicing). Do not remove.
      tow_eye: site at the center of the front axle, anchor for the
               PIVOT_MODE tow link.
  -->
  <compiler angle="degree"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="5 5" texuniform="true"/>
    <material name="truck_mat" rgba="0.2 0.45 0.75 1"/>
    <material name="trailer_mat" rgba="0.75 0.3 0.2 1"/>
    <material name="cargo_mat" rgba="0.85 0.7 0.3 1"/>
    <material name="tire_mat" rgba="0.08 0.08 0.08 1"/>
    <material name="lane_mat" rgba="0.95 0.8 0.06 1"/>
  </asset>

  <default>
    <geom condim="3" friction="1.2 0.005 0.0001" contype="1" conaffinity="1"/>
    <default class="tire">
      <geom type="cylinder" material="tire_mat" friction="1.3 0.005 0.0001" contype="2" conaffinity="2" priority="1"/>
    </default>
    <default class="spin">
      <joint type="hinge" axis="0 1 0" damping="0.5"/>
    </default>
  </default>

  <worldbody>
    <light pos="0 0 10" dir="0 0 -1" directional="true"/>
    <geom name="floor" type="plane" size="500 200 0.1" material="grid" contype="3" conaffinity="3"/>

    <!-- ===== LANE: 3.66 m wide, yellow lines both sides, no collision ===== -->
    <geom name="lane_line_left"  type="box" size="500 0.05 0.001" pos="0  1.83 0.002" material="lane_mat" contype="0" conaffinity="0"/>
    <geom name="lane_line_right" type="box" size="500 0.05 0.001" pos="0 -1.83 0.002" material="lane_mat" contype="0" conaffinity="0"/>

    <!-- ================= PICKUP TRUCK (single block, no suspension) ================= -->
    <!-- CAR_ROOT_START -->
    <body name="car" pos="0 0 0.60">
      <freejoint name="car_root"/>
    <!-- CAR_ROOT_END -->
      <inertial pos="0.26 0 0.10" mass="2200" diaginertia="1300 5500 6000"/>
      <geom name="truck_block" type="box" size="2.95 1.015 0.80" pos="0 0 0.55" material="truck_mat"/>
      <site name="imu_car" pos="0.26 0 0.10" size="0.03" rgba="1 0 0 0.5"/>
      <site name="tow_eye" pos="1.85 0 -0.19" size="0.03" rgba="0 1 0 0.8"/>

      <!-- front: steer knuckle + wheel, rigid mount at z = -0.19 (tire r 0.41) -->
      <body name="fl_knuckle" pos="1.85 0.86 -0.19">
        <joint name="fl_steer" type="hinge" axis="0 0 1" range="-35 35" damping="20"/>
        <geom type="sphere" size="0.05" mass="8" material="truck_mat" contype="0" conaffinity="0"/>
        <body name="fl_wheel">
          <joint name="fl_hinge" class="spin"/>
          <geom name="fl_tire" class="tire" size="0.41 0.1375" zaxis="0 1 0" mass="45"/>
        </body>
      </body>
      <body name="fr_knuckle" pos="1.85 -0.86 -0.19">
        <joint name="fr_steer" type="hinge" axis="0 0 1" range="-35 35" damping="20"/>
        <geom type="sphere" size="0.05" mass="8" material="truck_mat" contype="0" conaffinity="0"/>
        <body name="fr_wheel">
          <joint name="fr_hinge" class="spin"/>
          <geom name="fr_tire" class="tire" size="0.41 0.1375" zaxis="0 1 0" mass="45"/>
        </body>
      </body>

      <!-- rear (driven), rigid mount -->
      <body name="rl_wheel" pos="-1.85 0.86 -0.19">
        <joint name="rl_hinge" class="spin"/>
        <geom name="rl_tire" class="tire" size="0.41 0.1375" zaxis="0 1 0" mass="45"/>
      </body>
      <body name="rr_wheel" pos="-1.85 -0.86 -0.19">
        <joint name="rr_hinge" class="spin"/>
        <geom name="rr_tire" class="tire" size="0.41 0.1375" zaxis="0 1 0" mass="45"/>
      </body>

      <!-- TRAILER_START -->
      <body name="trailer" pos="-3.10 0 -0.15">
        <joint name="hitch" type="ball" limited="true" range="0 45" damping="0.5"/>
        <site name="imu_trailer" pos="-2.720 0 0.10" size="0.03" rgba="1 0 0 0.5"/>
        <geom name="trailer_tongue" type="box" size="0.750 0.05 0.04" pos="-0.750 0 0" mass="45" material="trailer_mat"/>
        <geom name="trailer_bed" type="box" size="1.22 0.76 0.06" pos="-2.720 0 0.10" mass="250" material="trailer_mat"/>
        <geom name="cargo" type="box" size="0.50 0.60 0.25" pos="-2.620 0 0.41" mass="350" material="cargo_mat"/>
        <body name="tl_wheel" pos="-2.720 0.88 -0.105">
          <joint name="tl_hinge" class="spin"/>
          <geom name="tl_tire" class="tire" size="0.345 0.1025" zaxis="0 1 0" mass="25" friction="0.9 0.005 0.0001"/>
        </body>
        <body name="tr_wheel" pos="-2.720 -0.88 -0.105">
          <joint name="tr_hinge" class="spin"/>
          <geom name="tr_tire" class="tire" size="0.345 0.1025" zaxis="0 1 0" mass="25" friction="0.9 0.005 0.0001"/>
        </body>
      </body>
      <!-- TRAILER_END -->
    </body>
    <!-- CAR_END -->
  </worldbody>

  <actuator>
    <velocity name="drive_left"  joint="rl_hinge" kv="150" ctrlrange="0 60"/>
    <velocity name="drive_right" joint="rr_hinge" kv="150" ctrlrange="0 60"/>
    <position name="steer_left"  joint="fl_steer" kp="9000" kv="400" ctrlrange="-0.61 0.61"/>
    <position name="steer_right" joint="fr_steer" kp="9000" kv="400" ctrlrange="-0.61 0.61"/>
  </actuator>

  <sensor>
    <!-- truck IMU -->
    <accelerometer name="car_imu_accel" site="imu_car"/>
    <gyro name="car_imu_gyro" site="imu_car"/>
    <framequat name="car_imu_quat" objtype="site" objname="imu_car"/>
    <!-- trailer IMU -->
    <accelerometer name="trailer_imu_accel" site="imu_trailer"/>
    <gyro name="trailer_imu_gyro" site="imu_trailer"/>
    <framequat name="trailer_imu_quat" objtype="site" objname="imu_trailer"/>
    <!-- trailer angle relative to truck (ball joint quaternion) -->
    <ballquat name="hitch_angle" joint="hitch"/>
    <framepos name="trailer_pos" objtype="body" objname="trailer"/>
    <frameyaxis name="trailer_yaxis" objtype="body" objname="trailer"/>
  </sensor>
</mujoco>
