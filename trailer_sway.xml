<mujoco model="trailer_sway">
    <compiler angle="degree"/>
    <option timestep="0.005" gravity="0 0 -9.81"/>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" width="512" height="512"/>
        <material name="grid" texture="grid" texrepeat="5 5" texuniform="true"/>
        <material name="car_mat" rgba="0.2 0.6 0.8 1"/>
        <material name="trailer_mat" rgba="0.8 0.3 0.2 1"/>
        <material name="wheel_mat" rgba="0.1 0.1 0.1 1"/>
    </asset>

    <default>
        <geom condim="3" friction="1 0.005 0.0001"/>
        <joint damping="0.05"/>
    </default>

    <worldbody>
        <light pos="0 0 5" dir="0 0 -1" directional="true"/>
        <geom name="floor" type="plane" size="100 100 0.1" material="grid"/>

        <body name="car" pos="0 0 0.2">
            <freejoint name="car_root"/>
            <geom name="car_body" type="box" size="0.6 0.3 0.1" mass="4300" material="car_mat"/>

            <body name="fl_wheel" pos="0.4 0.35 0">
                <joint name="fl_hinge" type="hinge" axis="0 1 0"/>
                <geom type="cylinder" size="0.15 0.05" zaxis="0 1 0" material="wheel_mat"/>
            </body>
            <body name="fr_wheel" pos="0.4 -0.35 0">
                <joint name="fr_hinge" type="hinge" axis="0 1 0"/>
                <geom type="cylinder" size="0.15 0.05" zaxis="0 1 0" material="wheel_mat"/>
            </body>

            <body name="rl_wheel" pos="-0.4 0.35 0">
                <joint name="rl_hinge" type="hinge" axis="0 1 0"/>
                <geom type="cylinder" size="0.15 0.05" zaxis="0 1 0" material="wheel_mat"/>
            </body>
            <body name="rr_wheel" pos="-0.4 -0.35 0">
                <joint name="rr_hinge" type="hinge" axis="0 1 0"/>
                <geom type="cylinder" size="0.15 0.05" zaxis="0 1 0" material="wheel_mat"/>
            </body>

            <body name="trailer" pos="-0.7 0 0">
                <joint name="hitch" type="ball" limited="true" range="0 90" damping="0.1"/>
                <inertial pos="-0.6 0 0" mass="2000" diaginertia="0.5 0.5 0.5"/>

                <geom name="trailer_tongue" type="box" size="0.2 0.05 0.05" pos="-0.2 0 0" material="trailer_mat"/>
                <geom name="trailer_body" type="box" size="0.4 0.3 0.1" pos="-0.6 0 0" material="trailer_mat"/>

                <body name="tl_wheel" pos="-0.4 0.35 0">
                    <joint name="tl_hinge" type="hinge" axis="0 1 0"/>
                    <geom type="cylinder" size="0.15 0.05" zaxis="0 1 0" material="wheel_mat"/>
                </body>
                <body name="tr_wheel" pos="-0.4 -0.35 0">
                    <joint name="tr_hinge" type="hinge" axis="0 1 0"/>
                    <geom type="cylinder" size="0.15 0.05" zaxis="0 1 0" material="wheel_mat"/>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <velocity name="drive_left" joint="rl_hinge" kv="15" ctrlrange="0 100"/>
        <velocity name="drive_right" joint="rr_hinge" kv="15" ctrlrange="0 100"/>
    </actuator>
</mujoco>