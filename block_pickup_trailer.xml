<mujoco model="block_pickup_trailer">
  <!--
      Simplified block-body pickup + block flatbed trailer, real scale.

      TRUCK : single box 5.90 x 2.03 x 1.60 m (bottom 0.35 m, roof 1.95 m).
              Mass/COM set by an explicit <inertial> element, NOT by the box:
                sprung mass 2200 kg (+ ~300 kg wheels/susp -> ~2500 kg curb)
                COM 0.26 m ahead of mid-wheelbase (57/43 F/R), 0.70 m high
                diaginertia ~ full-size pickup (roll 1300, pitch 5500, yaw 6000)
              Wheelbase 3.70 m, track 1.72 m, tires 275/65R18 (r=0.41, w=0.275)

      TRAILER: single flat box 2.44 x 1.52 m deck, single axle AT DECK CENTER,
              tongue bar of length TONGUE_LEN from ball to deck edge,
              tires ST205/75R15 (r=0.345, w=0.205).
              Payload box sits on the deck; its fore/aft position sets the
              payload-system COM relative to the axle.

      The trailer section between the TRAILER_START/END markers is
      regenerated by the Python script (tongue length, cargo position/mass,
      tire friction, hitch damping, spring preload). Defaults below are a
      loadable standalone configuration: tongue 1.50 m, cargo +0.10 m
      ahead of the axle, 350 kg.

      Suspension: vertical slide joint per wheel.
        truck front : k = 50 kN/m, c = 4200 Ns/m
        truck rear  : k = 42 kN/m, c = 3800 Ns/m
        trailer     : k = 35 kN/m, c =  900 Ns/m (underdamped, sway-prone)
  -->
  <compiler angle="degree"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="5 5" texuniform="true"/>
    <material name="truck_mat" rgba="0.2 0.45 0.75 1"/>
    <material name="trailer_mat" rgba="0.75 0.3 0.2 1"/>
    <material name="cargo_mat" rgba="0.85 0.7 0.3 1"/>
    <material name="tire_mat" rgba="0.08 0.08 0.08 1"/>
  </asset>

  <default>
    <geom condim="3" friction="1.2 0.005 0.0001" contype="1" conaffinity="1"/>
    <default class="tire">
      <geom type="cylinder" material="tire_mat" friction="1.3 0.005 0.0001" contype="2" conaffinity="2" priority="1"/>
    </default>
    <default class="spin">
      <joint type="hinge" axis="0 1 0" damping="0.5"/>
    </default>
  </default>

  <worldbody>
    <light pos="0 0 10" dir="0 0 -1" directional="true"/>
    <geom name="floor" type="plane" size="200 200 0.1" material="grid" contype="3" conaffinity="3"/>

    <!-- ================= PICKUP TRUCK (single block) ================= -->
    <!-- body frame at mid-wheelbase, 0.60 m ride height -->
    <body name="car" pos="0 0 0.60">
      <freejoint name="car_root"/>
      <!-- COM: x=+0.26 (57/43 split over 3.70 m wheelbase), z world = 0.70 m -->
      <inertial pos="0.26 0 0.10" mass="2200" diaginertia="1300 5500 6000"/>
      <!-- the block: geom mass is ignored because inertial is explicit -->
      <geom name="truck_block" type="box" size="2.95 1.015 0.80" pos="0 0 0.55" material="truck_mat"/>

      <!-- ======== front suspension + steering ========
           corner sprung ~627 kg -> springref = -mg/k = -0.123 -->
      <body name="fl_susp" pos="1.85 0.86 -0.19">
        <joint name="fl_susp" type="slide" axis="0 0 1" range="-0.13 0.13" stiffness="50000" damping="4200" springref="-0.123"/>
        <geom type="sphere" size="0.06" mass="25" material="truck_mat" contype="0" conaffinity="0"/>
        <body name="fl_knuckle">
          <joint name="fl_steer" type="hinge" axis="0 0 1" range="-35 35" damping="20"/>
          <geom type="sphere" size="0.05" mass="8" material="truck_mat" contype="0" conaffinity="0"/>
          <body name="fl_wheel">
            <joint name="fl_hinge" class="spin"/>
            <geom class="tire" size="0.41 0.1375" zaxis="0 1 0" mass="45"/>
          </body>
        </body>
      </body>
      <body name="fr_susp" pos="1.85 -0.86 -0.19">
        <joint name="fr_susp" type="slide" axis="0 0 1" range="-0.13 0.13" stiffness="50000" damping="4200" springref="-0.123"/>
        <geom type="sphere" size="0.06" mass="25" material="truck_mat" contype="0" conaffinity="0"/>
        <body name="fr_knuckle">
          <joint name="fr_steer" type="hinge" axis="0 0 1" range="-35 35" damping="20"/>
          <geom type="sphere" size="0.05" mass="8" material="truck_mat" contype="0" conaffinity="0"/>
          <body name="fr_wheel">
            <joint name="fr_hinge" class="spin"/>
            <geom class="tire" size="0.41 0.1375" zaxis="0 1 0" mass="45"/>
          </body>
        </body>
      </body>

      <!-- ======== rear suspension (driven axle) ========
           corner sprung ~473 kg -> springref = -0.110 -->
      <body name="rl_susp" pos="-1.85 0.86 -0.19">
        <joint name="rl_susp" type="slide" axis="0 0 1" range="-0.13 0.13" stiffness="42000" damping="3800" springref="-0.110"/>
        <geom type="sphere" size="0.06" mass="25" material="truck_mat" contype="0" conaffinity="0"/>
        <body name="rl_wheel">
          <joint name="rl_hinge" class="spin"/>
          <geom class="tire" size="0.41 0.1375" zaxis="0 1 0" mass="45"/>
        </body>
      </body>
      <body name="rr_susp" pos="-1.85 -0.86 -0.19">
        <joint name="rr_susp" type="slide" axis="0 0 1" range="-0.13 0.13" stiffness="42000" damping="3800" springref="-0.110"/>
        <geom type="sphere" size="0.06" mass="25" material="truck_mat" contype="0" conaffinity="0"/>
        <body name="rr_wheel">
          <joint name="rr_hinge" class="spin"/>
          <geom class="tire" size="0.41 0.1375" zaxis="0 1 0" mass="45"/>
        </body>
      </body>

      <!-- TRAILER_START -->
      <!-- ================= FLATBED TRAILER (single block) =================
           origin at the hitch ball: 0.15 m behind the truck block, 0.45 m high.
           tongue length L = 1.50 -> axle (deck center) at x = -(L+1.22) = -2.72 -->
      <body name="trailer" pos="-3.10 0 -0.15">
        <joint name="hitch" type="ball" limited="true" range="0 45" damping="0.5"/>
        <!-- tongue bar: length = TONGUE_LEN, ball to deck front edge -->
        <geom name="trailer_tongue" type="box" size="0.750 0.05 0.04" pos="-0.750 0 0" mass="45" material="trailer_mat"/>
        <!-- flatbed block: 2.44 x 1.52 m deck, top at 0.61 m world -->
        <geom name="trailer_bed" type="box" size="1.22 0.76 0.06" pos="-2.720 0 0.10" mass="250" material="trailer_mat"/>
        <!-- payload block: default 0.10 m AHEAD of the axle (stable) -->
        <geom name="cargo" type="box" size="0.50 0.60 0.25" pos="-2.620 0 0.41" mass="350" material="cargo_mat"/>

        <!-- single axle at deck center; corner sprung ~274 kg -> springref = -0.077 -->
        <body name="tl_susp" pos="-2.720 0.88 -0.105">
          <joint name="tl_susp" type="slide" axis="0 0 1" range="-0.10 0.10" stiffness="35000" damping="900" springref="-0.077"/>
          <geom type="sphere" size="0.05" mass="12" material="trailer_mat" contype="0" conaffinity="0"/>
          <body name="tl_wheel">
            <joint name="tl_hinge" class="spin"/>
            <geom class="tire" size="0.345 0.1025" zaxis="0 1 0" mass="25" friction="0.9 0.005 0.0001"/>
          </body>
        </body>
        <body name="tr_susp" pos="-2.720 -0.88 -0.105">
          <joint name="tr_susp" type="slide" axis="0 0 1" range="-0.10 0.10" stiffness="35000" damping="900" springref="-0.077"/>
          <geom type="sphere" size="0.05" mass="12" material="trailer_mat" contype="0" conaffinity="0"/>
          <body name="tr_wheel">
            <joint name="tr_hinge" class="spin"/>
            <geom class="tire" size="0.345 0.1025" zaxis="0 1 0" mass="25" friction="0.9 0.005 0.0001"/>
          </body>
        </body>
      </body>
      <!-- TRAILER_END -->
    </body>
  </worldbody>

  <actuator>
    <!-- rear-wheel drive; ctrl = target wheel speed in rad/s
         (ctrl 50 -> ~20.5 m/s -> ~46 mph) -->
    <velocity name="drive_left"  joint="rl_hinge" kv="150" ctrlrange="0 60"/>
    <velocity name="drive_right" joint="rr_hinge" kv="150" ctrlrange="0 60"/>
    <!-- steering: position actuator ctrl is in radians (+-0.61 rad = +-35 deg) -->
    <position name="steer_left"  joint="fl_steer" kp="9000" kv="400" ctrlrange="-0.61 0.61"/>
    <position name="steer_right" joint="fr_steer" kp="9000" kv="400" ctrlrange="-0.61 0.61"/>
  </actuator>

  <sensor>
    <framepos  name="trailer_pos"   objtype="body" objname="trailer"/>
    <frameyaxis name="trailer_yaxis" objtype="body" objname="trailer"/>
  </sensor>
</mujoco>
